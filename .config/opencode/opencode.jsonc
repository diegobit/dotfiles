{
    "$schema": "https://opencode.ai/config.jsonc",
    "autoupdate": true,
    "mcp": {
      "chrome-devtools": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "chrome-devtools-mcp@latest",
          "--no-usage-statistics",
          "--no-performance-crux"
        ],
        "enabled": true
      },
      "playwright": {
        "type": "local",
        "command": [
          "npx",
          "@playwright/mcp@latest",
          "--browser",
          "chromium",
          "--caps",
          "devtools"
        ],
        "enabled": true
      }
    }
  //"plugin": ["@mohak34/opencode-notifier@latest"]
}
