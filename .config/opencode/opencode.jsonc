{
    "$schema": "https://opencode.ai/config.jsonc",
    "autoupdate": true,
    "mcp": {
      "chrome-devtools": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "chrome-devtools-mcp@latest",
          "--no-usage-statistics",
          "--no-performance-crux"
        ],
        "enabled": true
      },
      "playwright": {
        "type": "local",
        "command": [
          "npx",
          "@playwright/mcp@latest",
          "--browser",
          "chromium",
          "--caps",
          "devtools"
        ],
        "enabled": true
      },
      "icloud-mail": {
        "type": "remote",
        "url": "https://icloud-mail.diegobit.com/mcp",
        "enabled": true,
        "oauth": false,
        "headers": {
          "Authorization": "Bearer {env:ICLOUD_MAIL_TOKEN}"
        }
      }
    }
  //"plugin": ["@mohak34/opencode-notifier@latest"]
}
